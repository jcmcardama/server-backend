PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL via pgAdmin)
DATABASE_URL="postgresql://postgres:your_secure_password@localhost:5432/db_name?schema=public"

# Security Secrets (Generate strong strings for production!)
ACCESS_TOKEN_SECRET=your_super_secret_access_token_key_123!
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_key_456!