datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  password     String
  refreshToken String?  // Nullable, used to store the active session token
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users") // Maps the model to a lowercase table name in PostgreSQL
}